# ======================================
# 行尾换行符统一（LF）
# ======================================
* text=auto eol=lf

# ======================================
# 二进制文件
# ======================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary
*.mpg binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary

# ======================================
# 文本文件（明确指定）
# ======================================
*.js text
*.jsx text
*.ts text
*.tsx text
*.vue text
*.json text
*.md text
*.txt text
*.html text
# *.svg text
*.css text
*.scss text
*.sass text
*.less text

# ======================================
# 配置文件
# ======================================
*.config text
*.rc text
*.env text

# ======================================
# 合并策略
# ======================================
# package.json 使用标准合并
package.json merge=union
# 锁定文件使用 ours 策略（避免冲突）
package-lock.json merge=ours
yarn.lock merge=ours
pnpm-lock.yaml merge=ours
